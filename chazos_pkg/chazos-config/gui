#!/bin/bash
# Chazos GUI Launcher
# If Sway is already running, just exec the command as a new pane.
# Otherwise, start the Chazos session.

if [ -z "$1" ]; then
    # Default to terminal if no command provided
    CMD="kitty"
else
    CMD="$@"
fi

if [ -z "$XDG_RUNTIME_DIR" ]; then
    export XDG_RUNTIME_DIR=/run/user/$(id -u)
    if [ ! -d "$XDG_RUNTIME_DIR" ]; then
        mkdir -p "$XDG_RUNTIME_DIR"
        chmod 700 "$XDG_RUNTIME_DIR"
    fi
fi

if [ -n "$SWAYSOCK" ]; then
    swaymsg exec -- "$CMD"
else
    # Start Sway with the Chazos config. 
    # The config itself is set to auto-start a terminal.
    sway -c /etc/skel/.config/sway/chazos.conf
fi
